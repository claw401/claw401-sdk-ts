{
  "name": "@claw401/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Claw401 wallet authentication protocol",
  "author": "Claw401 Protocol",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.2"
  },
  "keywords": [
    "solana",
    "authentication",
    "wallet",
    "web3",
    "x401",
    "agent",
    "identity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/claw401"
  }
}
